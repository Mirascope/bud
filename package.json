{
  "name": "@mirascope/bud",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "demo",
    "packages/*"
  ],
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run format:check && bun run lint && bun run typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.7.0",
    "oxlint": "^0.16.6",
    "typescript": "^5.7.3"
  }
}
