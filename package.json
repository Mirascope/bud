{
  "name": "@mirascope/bud",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "workspaces": [
    "demo",
    "packages/*"
  ],
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run format:check && bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@bud/agent": "workspace:*",
    "@bud/computer": "workspace:*",
    "@bud/cron": "workspace:*",
    "@bud/gateway": "workspace:*",
    "@bud/identity": "workspace:*",
    "@bud/journal": "workspace:*",
    "@bud/llm": "workspace:*",
    "@bud/object-storage": "workspace:*",
    "@bud/sessions": "workspace:*",
    "@bud/tools": "workspace:*",
    "effect": "^3.19.18"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.7.0",
    "oxlint": "^0.16.6",
    "typescript": "^5.7.3"
  }
}
